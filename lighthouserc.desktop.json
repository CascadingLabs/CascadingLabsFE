{
	"ci": {
		"collect": {
			"staticDistDir": "./dist",
			"numberOfRuns": 3,
			"settings": {
				"preset": "desktop",
				"chromeFlags": ["--no-sandbox", "--disable-features=Translate"],
				"skipAudits": ["inspector-issues", "is-crawlable"]
			},
			"url": [
				"/",
				"/contributing/",
				"/yosoi/",
				"/yosoi/quickstart/",
				"/guides/selectors/",
				"/reference/functions/",
				"/roadmap/"
			]
		},
		"assert": {
			"assertions": {
				"categories:performance": ["error", { "minScore": 0.99 }],
				"categories:accessibility": ["error", { "minScore": 0.95 }],
				"categories:best-practices": ["error", { "minScore": 1 }],
				"categories:seo": ["error", { "minScore": 1 }]
			}
		},
		"upload": {
			"target": "temporary-public-storage"
		}
	}
}
