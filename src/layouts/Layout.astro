---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Cascading Labs' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-[#0b0c0d] text-[#d4d4d4] antialiased flex justify-center min-h-screen py-20 px-5">
		<div class="w-full max-w-[720px] border-x border-[#2a2a2a] px-10">
			<slot />
		</div>
	</body>
</html>

<style is:global>
	::selection {
		background: #64748b;
		color: #fff;
	}
</style>
