---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DNA · Wave · Funnel | Cascading Labs" description="DNA, wave, and Y-funnel logo iterations.">
    <h1 class="text-xl font-medium mb-2 tracking-tight" style="color: var(--cl-text);">DNA · Wave · Y-Funnel</h1>
    <p class="mb-10 font-light text-sm" style="color: var(--cl-text-dim);">CL helix + wave iterations · YS funnel · draw · B&amp;W</p>

    <!-- ═══ DNA · CL ═══ -->
    <h2 class="text-sm font-medium mb-4 tracking-wide" style="color: var(--cl-text-dim);">DNA · CL</h2>
    <div class="grid grid-cols-5 gap-6 max-w-4xl mb-16">
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 68 16 C 68 56 132 56 132 96 C 132 136 68 136 68 176" stroke-width="5" class="da da1"/>
                    <path d="M 132 16 C 132 56 68 56 68 96 C 68 136 132 136 132 176" stroke-width="5" class="da da2"/>
                </g>
            </svg>
            <span class="label">dna · classic</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 64 16 C 64 56 136 56 136 96 C 136 136 64 136 64 176" stroke-width="4" class="da da1"/>
                    <path d="M 136 16 C 136 56 64 56 64 96 C 64 136 136 136 136 176" stroke-width="4" class="da da2"/>
                    <line x1="76" y1="36" x2="124" y2="36" stroke-width="3" class="drg drg1"/>
                    <line x1="70" y1="56" x2="130" y2="56" stroke-width="3" class="drg drg2"/>
                    <line x1="76" y1="76" x2="124" y2="76" stroke-width="3" class="drg drg3"/>
                    <line x1="82" y1="96" x2="118" y2="96" stroke-width="3" class="drg drg4"/>
                    <line x1="76" y1="116" x2="124" y2="116" stroke-width="3" class="drg drg5"/>
                    <line x1="70" y1="136" x2="130" y2="136" stroke-width="3" class="drg drg6"/>
                    <line x1="76" y1="156" x2="124" y2="156" stroke-width="3" class="drg drg7"/>
                </g>
            </svg>
            <span class="label">dna · runged</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-width="5" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M 64 20 L 136 56 L 64 92 L 136 128 L 64 164" class="dza"/>
                    <path d="M 136 20 L 64 56 L 136 92 L 64 128 L 136 164" class="dzb"/>
                </g>
                <g fill="#fff">
                    <rect x="95" y="33" width="10" height="10" class="dzn dzn1"/>
                    <rect x="95" y="69" width="10" height="10" class="dzn dzn2"/>
                    <rect x="95" y="105" width="10" height="10" class="dzn dzn3"/>
                    <rect x="95" y="141" width="10" height="10" class="dzn dzn4"/>
                </g>
            </svg>
            <span class="label">dna · angular</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 60 16 C 60 56 140 56 140 96 C 140 136 60 136 60 176" stroke-width="3" class="da da1"/>
                    <path d="M 140 16 C 140 56 60 56 60 96 C 60 136 140 136 140 176" stroke-width="3" class="da da2"/>
                    <line x1="70" y1="36" x2="130" y2="36" stroke-width="8" class="dcb dcb1"/>
                    <line x1="68" y1="56" x2="132" y2="56" stroke-width="8" class="dcb dcb2"/>
                    <line x1="72" y1="76" x2="128" y2="76" stroke-width="8" class="dcb dcb3"/>
                    <line x1="78" y1="96" x2="122" y2="96" stroke-width="8" class="dcb dcb4"/>
                    <line x1="72" y1="116" x2="128" y2="116" stroke-width="8" class="dcb dcb5"/>
                    <line x1="68" y1="136" x2="132" y2="136" stroke-width="8" class="dcb dcb6"/>
                    <line x1="70" y1="156" x2="130" y2="156" stroke-width="8" class="dcb dcb7"/>
                </g>
            </svg>
            <span class="label">dna · cascade</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 68 16 C 68 56 132 56 132 96 C 132 136 68 136 68 176" stroke-width="5" class="dhs"/>
                    <line x1="80" y1="36" x2="110" y2="36" stroke-width="3" class="dhst dhst1"/>
                    <line x1="92" y1="56" x2="124" y2="56" stroke-width="3" class="dhst dhst2"/>
                    <line x1="108" y1="76" x2="130" y2="76" stroke-width="3" class="dhst dhst3"/>
                    <line x1="118" y1="96" x2="130" y2="96" stroke-width="3" class="dhst dhst4"/>
                    <line x1="108" y1="116" x2="124" y2="116" stroke-width="3" class="dhst dhst5"/>
                    <line x1="80" y1="136" x2="110" y2="136" stroke-width="3" class="dhst dhst6"/>
                    <line x1="72" y1="156" x2="94" y2="156" stroke-width="3" class="dhst dhst7"/>
                </g>
            </svg>
            <span class="label">dna · half</span>
        </div>
    </div>

    <!-- ═══ WAVE · CL ═══ -->
    <h2 class="text-sm font-medium mb-4 tracking-wide" style="color: var(--cl-text-dim);">WAVE · CL</h2>
    <div class="grid grid-cols-5 gap-6 max-w-4xl mb-16">
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 24 70 C 50 50 74 90 100 70 C 126 50 150 90 176 70" stroke-width="7" class="wvl wvl1"/>
                    <path d="M 36 110 C 58 92 78 128 100 110 C 122 92 142 128 164 110" stroke-width="6" class="wvl wvl2"/>
                    <path d="M 50 148 C 66 134 84 162 100 148 C 116 134 134 162 150 148" stroke-width="5" class="wvl wvl3"/>
                </g>
            </svg>
            <span class="label">wave · waterfall</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 20 60 C 46 40 70 80 100 60 C 130 40 154 80 180 60" stroke-width="6" class="wvl wvl1"/>
                    <path d="M 34 100 C 52 86 76 114 100 100 C 124 86 148 114 166 100" stroke-width="5" class="wvl wvl2"/>
                    <path d="M 52 138 C 64 128 82 148 100 138 C 118 128 136 148 148 138" stroke-width="4" class="wvl wvl3"/>
                    <path d="M 74 170 C 82 164 90 176 100 170 C 110 164 118 176 126 170" stroke-width="3" class="wvl wvl4"/>
                </g>
            </svg>
            <span class="label">wave · converge</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 20 100 L 56 100 L 68 50 L 84 150 L 96 68 L 104 118 L 112 88 L 120 104 L 128 100 L 180 100" stroke-width="5" class="wpm"/>
                    <path d="M 20 140 L 60 140 L 68 118 L 78 160 L 86 128 L 94 148 L 100 138 L 108 142 L 114 140 L 180 140" stroke-width="3" class="wpe wpe1"/>
                    <path d="M 20 168 L 64 168 L 70 158 L 78 178 L 84 164 L 90 172 L 94 168 L 180 168" stroke-width="2" class="wpe wpe2"/>
                </g>
            </svg>
            <span class="label">wave · pulse</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 30 56 C 72 20 128 20 170 56" stroke-width="6" class="wsh wsh1"/>
                    <path d="M 30 108 C 55 82 75 82 100 108 C 125 134 145 134 170 108" stroke-width="5" class="wsh wsh2"/>
                    <path d="M 30 160 C 47 142 57 142 76 160 C 95 178 105 178 124 160 C 143 142 153 142 170 160" stroke-width="4" class="wsh wsh3"/>
                </g>
                <g fill="#fff">
                    <rect x="24" y="50" width="8" height="8"/><rect x="168" y="50" width="8" height="8"/>
                    <rect x="24" y="102" width="8" height="8"/><rect x="168" y="102" width="8" height="8"/>
                    <rect x="24" y="154" width="8" height="8"/><rect x="168" y="154" width="8" height="8"/>
                </g>
            </svg>
            <span class="label">wave · standing</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 20 80 C 60 50 140 110 180 80" stroke-width="5" class="wis wis1"/>
                    <path d="M 20 130 C 60 100 140 160 180 130" stroke-width="5" class="wis wis2"/>
                    <path d="M 20 80 C 35 68 45 92 60 80 C 75 68 85 92 100 80 C 115 68 125 92 140 80 C 155 68 165 92 180 80" stroke-width="2" class="wif wif1"/>
                    <path d="M 20 130 C 35 118 45 142 60 130 C 75 118 85 142 100 130 C 115 118 125 142 140 130 C 155 118 165 142 180 130" stroke-width="2" class="wif wif2"/>
                </g>
            </svg>
            <span class="label">wave · interfere</span>
        </div>
    </div>

    <!-- ═══ Y-FUNNEL · YS ═══ -->
    <h2 class="text-sm font-medium mb-4 tracking-wide" style="color: var(--cl-text-dim);">Y-FUNNEL · YS</h2>
    <div class="grid grid-cols-5 gap-6 max-w-4xl">
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-width="6" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M 40 24 L 100 100 L 100 180" class="yfl"/>
                    <path d="M 160 24 L 100 100" class="yfr"/>
                </g>
            </svg>
            <span class="label">funnel · clean</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M 30 20 L 100 108 L 100 180" stroke-width="7" class="yfl"/>
                    <path d="M 170 20 L 100 108" stroke-width="7" class="yfr"/>
                </g>
                <g fill="#fff">
                    <rect x="95" y="130" width="10" height="10" class="yfd yfd1"/>
                    <rect x="95" y="148" width="10" height="10" class="yfd yfd2"/>
                    <rect x="95" y="166" width="10" height="10" class="yfd yfd3"/>
                </g>
            </svg>
            <span class="label">funnel · data</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-width="4" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M 34 20 L 92 96 L 92 180" class="yfo yfo1"/>
                    <path d="M 54 20 L 108 96 L 108 180" class="yfo yfo2"/>
                    <path d="M 166 20 L 108 96" class="yfo yfo3"/>
                    <path d="M 146 20 L 92 96" class="yfo yfo4"/>
                </g>
            </svg>
            <span class="label">funnel · outline</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <path d="M 36 20 L 100 104 L 100 180" stroke-width="5" class="yfl"/>
                    <path d="M 164 20 L 100 104" stroke-width="5" class="yfr"/>
                    <line x1="52" y1="40" x2="148" y2="40" stroke-width="2" class="yfw yfw1"/>
                    <line x1="64" y1="56" x2="136" y2="56" stroke-width="2" class="yfw yfw2"/>
                    <line x1="74" y1="72" x2="126" y2="72" stroke-width="2" class="yfw yfw3"/>
                    <line x1="84" y1="88" x2="116" y2="88" stroke-width="2" class="yfw yfw4"/>
                </g>
            </svg>
            <span class="label">funnel · web</span>
        </div>
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-width="5" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M 36 20 L 100 100 L 100 180" class="yfl"/>
                    <path d="M 164 20 L 100 100" class="yfr"/>
                    <line x1="88" y1="120" x2="112" y2="120" stroke-width="4" class="yfcb yfcb1"/>
                    <line x1="90" y1="140" x2="110" y2="140" stroke-width="4" class="yfcb yfcb2"/>
                    <line x1="92" y1="160" x2="108" y2="160" stroke-width="4" class="yfcb yfcb3"/>
                </g>
            </svg>
            <span class="label">funnel · cascade</span>
        </div>
    </div>
</Layout>

<style>
    .cell { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
    .label { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--cl-text-dim); letter-spacing: 0.06em; }

    /* DNA · classic */
    .da { stroke-dasharray: 400; stroke-dashoffset: 400; animation: draw 1.2s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .da1 { animation-delay: 0.1s; } .da2 { animation-delay: 0.3s; }

    /* DNA · runged */
    .drg { stroke-dasharray: 60; stroke-dashoffset: 60; animation: draw 0.2s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .drg1 { animation-delay: 0.3s; } .drg2 { animation-delay: 0.5s; } .drg3 { animation-delay: 0.7s; }
    .drg4 { animation-delay: 0.9s; } .drg5 { animation-delay: 1.1s; } .drg6 { animation-delay: 1.3s; } .drg7 { animation-delay: 1.5s; }

    /* DNA · angular */
    .dza { stroke-dasharray: 500; stroke-dashoffset: 500; animation: draw 1.2s cubic-bezier(0.22,0.6,0.36,1) 0.1s forwards; }
    .dzb { stroke-dasharray: 500; stroke-dashoffset: 500; animation: draw 1.2s cubic-bezier(0.22,0.6,0.36,1) 0.2s forwards; }
    .dzn { opacity: 0; animation: fadeIn 0.2s ease forwards; }
    .dzn1 { animation-delay: 0.4s; } .dzn2 { animation-delay: 0.7s; } .dzn3 { animation-delay: 1.0s; } .dzn4 { animation-delay: 1.3s; }

    /* DNA · cascade */
    .dcb { stroke-dasharray: 80; stroke-dashoffset: 80; animation: draw 0.3s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .dcb1 { animation-delay: 0.3s; } .dcb2 { animation-delay: 0.5s; } .dcb3 { animation-delay: 0.7s; }
    .dcb4 { animation-delay: 0.9s; } .dcb5 { animation-delay: 1.1s; } .dcb6 { animation-delay: 1.3s; } .dcb7 { animation-delay: 1.5s; }

    /* DNA · half */
    .dhs { stroke-dasharray: 400; stroke-dashoffset: 400; animation: draw 1.2s cubic-bezier(0.22,0.6,0.36,1) 0.1s forwards; }
    .dhst { stroke-dasharray: 50; stroke-dashoffset: 50; animation: draw 0.2s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .dhst1 { animation-delay: 0.3s; } .dhst2 { animation-delay: 0.5s; } .dhst3 { animation-delay: 0.7s; }
    .dhst4 { animation-delay: 0.9s; } .dhst5 { animation-delay: 1.1s; } .dhst6 { animation-delay: 1.3s; } .dhst7 { animation-delay: 1.5s; }

    /* WAVE · waterfall + converge */
    .wvl { stroke-dasharray: 200; stroke-dashoffset: 200; animation: draw 0.7s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .wvl1 { animation-delay: 0.1s; } .wvl2 { animation-delay: 0.4s; } .wvl3 { animation-delay: 0.7s; } .wvl4 { animation-delay: 1.0s; }

    /* WAVE · pulse */
    .wpm { stroke-dasharray: 500; stroke-dashoffset: 500; animation: draw 0.8s cubic-bezier(0.22,0.6,0.36,1) 0.1s forwards; }
    .wpe { stroke-dasharray: 400; stroke-dashoffset: 400; animation: draw 0.7s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .wpe1 { animation-delay: 0.6s; } .wpe2 { animation-delay: 1.0s; }

    /* WAVE · standing */
    .wsh { stroke-dasharray: 200; stroke-dashoffset: 200; animation: draw 0.7s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .wsh1 { animation-delay: 0.1s; } .wsh2 { animation-delay: 0.5s; } .wsh3 { animation-delay: 0.9s; }

    /* WAVE · interference */
    .wis { stroke-dasharray: 240; stroke-dashoffset: 240; animation: draw 1s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .wis1 { animation-delay: 0.1s; } .wis2 { animation-delay: 0.3s; }
    .wif { stroke-dasharray: 300; stroke-dashoffset: 300; animation: draw 1s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .wif1 { animation-delay: 0.5s; } .wif2 { animation-delay: 0.7s; }

    /* Y-FUNNEL */
    .yfl { stroke-dasharray: 250; stroke-dashoffset: 250; animation: draw 0.8s cubic-bezier(0.22,0.6,0.36,1) 0.1s forwards; }
    .yfr { stroke-dasharray: 120; stroke-dashoffset: 120; animation: draw 0.5s cubic-bezier(0.22,0.6,0.36,1) 0.15s forwards; }
    .yfd { opacity: 0; animation: fadeIn 0.2s ease forwards; }
    .yfd1 { animation-delay: 0.8s; } .yfd2 { animation-delay: 1.0s; } .yfd3 { animation-delay: 1.2s; }
    .yfo { stroke-dasharray: 300; stroke-dashoffset: 300; animation: draw 0.8s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .yfo1 { animation-delay: 0.1s; } .yfo2 { animation-delay: 0.2s; } .yfo3 { animation-delay: 0.15s; } .yfo4 { animation-delay: 0.25s; }
    .yfw { stroke-dasharray: 120; stroke-dashoffset: 120; animation: draw 0.25s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .yfw1 { animation-delay: 0.7s; } .yfw2 { animation-delay: 0.85s; } .yfw3 { animation-delay: 1.0s; } .yfw4 { animation-delay: 1.15s; }
    .yfcb { stroke-dasharray: 30; stroke-dashoffset: 30; animation: draw 0.2s cubic-bezier(0.22,0.6,0.36,1) forwards; }
    .yfcb1 { animation-delay: 0.8s; } .yfcb2 { animation-delay: 0.95s; } .yfcb3 { animation-delay: 1.1s; }

    @keyframes draw { to { stroke-dashoffset: 0; } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>
