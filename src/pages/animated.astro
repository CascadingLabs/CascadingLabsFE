---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="Animated Logos | Cascading Labs"
    description="Animated logo explorations for Cascading Labs and Yosoi."
>
    <h1 class="text-xl font-medium mb-2 tracking-tight" style="color: var(--cl-text);">
        🌊 Logo Animations
    </h1>
    <p class="mb-10 font-light text-sm" style="color: var(--cl-text-dim);">
        CL · lab marks &nbsp;|&nbsp; YS · abstract web &nbsp;|&nbsp; concepts &nbsp;|&nbsp; accent palette
    </p>

    <!-- ═══════════ CASCADING LABS ═══════════ -->
    <h2 class="section-title">🧪 CASCADING LABS</h2>
    <div class="grid grid-cols-5 gap-6 max-w-4xl mb-16">

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <path d="M 72 30 L 72 140 Q 72 170 100 170 Q 128 170 128 140 L 128 30" stroke="#90b8e0" stroke-width="6" class="tube-outline"/>
                    <line x1="62" y1="30" x2="138" y2="30" stroke="#fff" stroke-width="6" class="tube-cap"/>
                    <line x1="80" y1="100" x2="120" y2="100" stroke="#5b8cc7" stroke-width="5" class="tl tl1"/>
                    <line x1="80" y1="118" x2="120" y2="118" stroke="#5b8cc7" stroke-width="5" class="tl tl2"/>
                    <line x1="80" y1="136" x2="120" y2="136" stroke="#1e3a5f" stroke-width="5" class="tl tl3"/>
                    <line x1="84" y1="152" x2="116" y2="152" stroke="#1e3a5f" stroke-width="5" class="tl tl4"/>
                </g>
            </svg>
            <span class="label">CL · test tube</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-width="4" stroke-linecap="square">
                    <ellipse cx="100" cy="100" rx="70" ry="26" stroke="#90b8e0" class="orbit o1"/>
                    <ellipse cx="100" cy="100" rx="70" ry="26" stroke="#5b8cc7" transform="rotate(60 100 100)" class="orbit o2"/>
                    <ellipse cx="100" cy="100" rx="70" ry="26" stroke="#1e3a5f" transform="rotate(120 100 100)" class="orbit o3"/>
                </g>
                <rect x="94" y="94" width="12" height="12" fill="#fff" class="nucleus"/>
            </svg>
            <span class="label">CL · atom</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-width="4" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M 100 28 L 136 48 L 136 88 L 100 108 L 64 88 L 64 48 Z" stroke="#90b8e0" class="hex h1"/>
                    <path d="M 64 88 L 100 108 L 100 148 L 64 168 L 28 148 L 28 108 Z" stroke="#5b8cc7" class="hex h2"/>
                    <path d="M 136 88 L 172 108 L 172 148 L 136 168 L 100 148 L 100 108 Z" stroke="#1e3a5f" class="hex h3"/>
                </g>
                <g fill="#fff">
                    <rect x="96" y="24" width="8" height="8" class="node nd1"/>
                    <rect x="132" y="44" width="8" height="8" class="node nd2"/>
                    <rect x="132" y="84" width="8" height="8" class="node nd3"/>
                    <rect x="96" y="104" width="8" height="8" class="node nd4"/>
                    <rect x="60" y="84" width="8" height="8" class="node nd5"/>
                    <rect x="60" y="44" width="8" height="8" class="node nd6"/>
                </g>
            </svg>
            <span class="label">CL · lattice</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <path d="M 60 50 L 50 160 Q 50 175 65 175 L 135 175 Q 150 175 150 160 L 140 50" stroke="#90b8e0" stroke-width="5" class="beaker-body"/>
                    <line x1="50" y1="50" x2="150" y2="50" stroke="#fff" stroke-width="5" class="beaker-rim"/>
                    <path d="M 140 50 L 155 38" stroke="#fff" stroke-width="5" class="beaker-spout"/>
                    <line x1="68" y1="110" x2="132" y2="110" stroke="#5b8cc7" stroke-width="4" class="bl bl1"/>
                    <line x1="66" y1="128" x2="134" y2="128" stroke="#5b8cc7" stroke-width="4" class="bl bl2"/>
                    <line x1="64" y1="146" x2="136" y2="146" stroke="#1e3a5f" stroke-width="4" class="bl bl3"/>
                    <line x1="63" y1="162" x2="137" y2="162" stroke="#1e3a5f" stroke-width="4" class="bl bl4"/>
                </g>
            </svg>
            <span class="label">CL · beaker</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke="#1e3a5f" stroke-width="4" stroke-linecap="square">
                    <line x1="100" y1="60" x2="60" y2="110" class="bond b1"/>
                    <line x1="100" y1="60" x2="140" y2="110" class="bond b2"/>
                    <line x1="60" y1="110" x2="100" y2="160" class="bond b3"/>
                    <line x1="140" y1="110" x2="100" y2="160" class="bond b4"/>
                    <line x1="100" y1="60" x2="100" y2="28" class="bond b5"/>
                </g>
                <rect x="91" y="51" width="18" height="18" fill="#5b8cc7" class="atom-node an1"/>
                <rect x="51" y="101" width="18" height="18" fill="#90b8e0" class="atom-node an2"/>
                <rect x="131" y="101" width="18" height="18" fill="#90b8e0" class="atom-node an3"/>
                <rect x="91" y="151" width="18" height="18" fill="#fff" class="atom-node an4"/>
                <rect x="93" y="20" width="14" height="14" fill="#5b8cc7" class="atom-node an5"/>
            </svg>
            <span class="label">CL · molecule</span>
        </div>
    </div>

    <!-- ═══════════ YOSOI ═══════════ -->
    <h2 class="section-title">🕸️ YOSOI</h2>
    <div class="grid grid-cols-5 gap-6 max-w-4xl mb-16">

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <rect x="94" y="94" width="12" height="12" fill="#fff" class="rp-center"/>
                    <rect x="72" y="72" width="56" height="56" stroke="#90b8e0" stroke-width="3" class="pulse p1"/>
                    <rect x="50" y="50" width="100" height="100" stroke="#5b8cc7" stroke-width="2.5" class="pulse p2"/>
                    <rect x="28" y="28" width="144" height="144" stroke="#1e3a5f" stroke-width="2" class="pulse p3"/>
                    <line x1="28" y1="100" x2="72" y2="100" stroke="#5b8cc7" stroke-width="1.5" class="scan sc1"/>
                    <line x1="128" y1="100" x2="172" y2="100" stroke="#5b8cc7" stroke-width="1.5" class="scan sc2"/>
                </g>
            </svg>
            <span class="label">YS · pulse</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <line x1="100" y1="40" x2="50" y2="100" stroke="#1e3a5f" stroke-width="3" class="edge e1"/>
                    <line x1="100" y1="40" x2="150" y2="100" stroke="#1e3a5f" stroke-width="3" class="edge e2"/>
                    <line x1="50" y1="100" x2="80" y2="160" stroke="#1e3a5f" stroke-width="3" class="edge e3"/>
                    <line x1="150" y1="100" x2="120" y2="160" stroke="#1e3a5f" stroke-width="3" class="edge e4"/>
                    <line x1="50" y1="100" x2="150" y2="100" stroke="#1e3a5f" stroke-width="2" class="edge e5"/>
                    <line x1="80" y1="160" x2="120" y2="160" stroke="#1e3a5f" stroke-width="2" class="edge e6"/>
                </g>
                <rect x="90" y="30" width="20" height="20" fill="#90b8e0" class="gn gn1"/>
                <rect x="40" y="90" width="20" height="20" fill="#5b8cc7" class="gn gn2"/>
                <rect x="140" y="90" width="20" height="20" fill="#5b8cc7" class="gn gn3"/>
                <rect x="70" y="150" width="20" height="20" fill="#fff" class="gn gn4"/>
                <rect x="110" y="150" width="20" height="20" fill="#fff" class="gn gn5"/>
            </svg>
            <span class="label">YS · graph</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <line x1="32" y1="68" x2="168" y2="68" stroke="#90b8e0" stroke-width="8" class="wv wh1"/>
                    <line x1="32" y1="100" x2="168" y2="100" stroke="#5b8cc7" stroke-width="8" class="wv wh2"/>
                    <line x1="32" y1="132" x2="168" y2="132" stroke="#1e3a5f" stroke-width="8" class="wv wh3"/>
                    <line x1="68" y1="36" x2="68" y2="164" stroke="#fff" stroke-width="8" class="wv wv1"/>
                    <line x1="100" y1="36" x2="100" y2="164" stroke="#fff" stroke-width="8" class="wv wv2"/>
                    <line x1="132" y1="36" x2="132" y2="164" stroke="#fff" stroke-width="8" class="wv wv3"/>
                </g>
            </svg>
            <span class="label">YS · weave</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <circle cx="100" cy="100" r="28" stroke="#90b8e0" stroke-width="4" class="orb ob1"/>
                    <circle cx="100" cy="100" r="52" stroke="#5b8cc7" stroke-width="3" class="orb ob2"/>
                    <circle cx="100" cy="100" r="76" stroke="#1e3a5f" stroke-width="2" class="orb ob3"/>
                    <rect x="148" y="96" width="8" height="8" fill="#fff" class="orb-dot"/>
                    <path d="M 24 100 L 32 92" stroke="#90b8e0" stroke-width="3" fill="none" class="orb-tip"/>
                </g>
                <rect x="96" y="96" width="8" height="8" fill="#fff" class="orb-center"/>
            </svg>
            <span class="label">YS · orbit</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <path d="M 60 28 L 60 172" stroke="#90b8e0" stroke-width="4" class="flow fl1"/>
                    <path d="M 100 28 L 100 172" stroke="#5b8cc7" stroke-width="4" class="flow fl2"/>
                    <path d="M 140 28 L 140 172" stroke="#1e3a5f" stroke-width="4" class="flow fl3"/>
                    <line x1="60" y1="72" x2="100" y2="88" stroke="#fff" stroke-width="2" class="hop hp1"/>
                    <line x1="100" y1="108" x2="140" y2="124" stroke="#fff" stroke-width="2" class="hop hp2"/>
                    <line x1="140" y1="60" x2="100" y2="72" stroke="#fff" stroke-width="2" class="hop hp3"/>
                </g>
                <rect x="56" y="68" width="8" height="8" fill="#fff" class="dpkt dp1"/>
                <rect x="96" y="104" width="8" height="8" fill="#fff" class="dpkt dp2"/>
                <rect x="136" y="56" width="8" height="8" fill="#fff" class="dpkt dp3"/>
            </svg>
            <span class="label">YS · flow</span>
        </div>
    </div>

    <!-- ═══════════ CONCEPTS ═══════════ -->
    <h2 class="section-title">♾️ CONCEPTS · ∞ × web × time</h2>
    <div class="grid grid-cols-5 gap-6 max-w-4xl">

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <defs><linearGradient id="ig" x1="0%" x2="100%"><stop offset="0%" stop-color="#90b8e0"/><stop offset="50%" stop-color="#5b8cc7"/><stop offset="100%" stop-color="#1e3a5f"/></linearGradient></defs>
                <path d="M 100 100 C 100 60 36 48 36 100 C 36 152 100 140 100 100 C 100 60 164 48 164 100 C 164 152 100 140 100 100" fill="none" stroke="url(#ig)" stroke-width="6" stroke-linecap="square" class="inf-main"/>
                <rect x="94" y="94" width="12" height="12" fill="#fff" class="inf-center"/>
            </svg>
            <span class="label">∞ loop</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <path d="M 100 100 C 100 64 44 52 44 100 C 44 148 100 136 100 100 C 100 64 156 52 156 100 C 156 148 100 136 100 100" stroke="#5b8cc7" stroke-width="4" class="ic-loop"/>
                    <line x1="44" y1="62" x2="44" y2="72" stroke="#90b8e0" stroke-width="3" class="ict it1"/>
                    <line x1="44" y1="128" x2="44" y2="138" stroke="#90b8e0" stroke-width="3" class="ict it2"/>
                    <line x1="18" y1="100" x2="28" y2="100" stroke="#90b8e0" stroke-width="3" class="ict it3"/>
                    <line x1="60" y1="100" x2="70" y2="100" stroke="#90b8e0" stroke-width="3" class="ict it4"/>
                    <line x1="156" y1="62" x2="156" y2="72" stroke="#1e3a5f" stroke-width="3" class="ict it5"/>
                    <line x1="156" y1="128" x2="156" y2="138" stroke="#1e3a5f" stroke-width="3" class="ict it6"/>
                    <line x1="130" y1="100" x2="140" y2="100" stroke="#1e3a5f" stroke-width="3" class="ict it7"/>
                    <line x1="172" y1="100" x2="182" y2="100" stroke="#1e3a5f" stroke-width="3" class="ict it8"/>
                    <line x1="44" y1="100" x2="44" y2="76" stroke="#fff" stroke-width="3" class="ic-hand ih1"/>
                    <line x1="44" y1="100" x2="58" y2="88" stroke="#fff" stroke-width="2" class="ic-hand ih2"/>
                </g>
                <rect x="40" y="96" width="8" height="8" fill="#fff" class="ic-dot"/>
                <rect x="152" y="96" width="8" height="8" fill="#fff" class="ic-dot2"/>
            </svg>
            <span class="label">∞ clock</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <defs><linearGradient id="rg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#90b8e0"/><stop offset="100%" stop-color="#1e3a5f"/></linearGradient></defs>
                <g fill="none" stroke-linecap="square">
                    <path d="M 100 32 L 168 68 L 168 132 L 100 168 L 32 132 L 32 68 Z" stroke="url(#rg)" stroke-width="3" class="wr-ring"/>
                    <line x1="100" y1="32" x2="100" y2="168" stroke="#1e3a5f" stroke-width="1.5" class="wr-cross wc1"/>
                    <line x1="32" y1="68" x2="168" y2="132" stroke="#1e3a5f" stroke-width="1.5" class="wr-cross wc2"/>
                    <line x1="32" y1="132" x2="168" y2="68" stroke="#1e3a5f" stroke-width="1.5" class="wr-cross wc3"/>
                </g>
                <rect x="92" y="24" width="16" height="16" fill="#90b8e0" class="wr-node wn1"/>
                <rect x="160" y="60" width="16" height="16" fill="#5b8cc7" class="wr-node wn2"/>
                <rect x="160" y="124" width="16" height="16" fill="#5b8cc7" class="wr-node wn3"/>
                <rect x="92" y="160" width="16" height="16" fill="#90b8e0" class="wr-node wn4"/>
                <rect x="24" y="124" width="16" height="16" fill="#fff" class="wr-node wn5"/>
                <rect x="24" y="60" width="16" height="16" fill="#fff" class="wr-node wn6"/>
            </svg>
            <span class="label">web ring</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <line x1="100" y1="24" x2="100" y2="176" stroke="#1e3a5f" stroke-width="3" class="cc-spine"/>
                    <line x1="100" y1="40" x2="156" y2="40" stroke="#90b8e0" stroke-width="5" class="ctk ct1"/>
                    <line x1="100" y1="64" x2="148" y2="64" stroke="#90b8e0" stroke-width="5" class="ctk ct2"/>
                    <line x1="100" y1="88" x2="140" y2="88" stroke="#5b8cc7" stroke-width="5" class="ctk ct3"/>
                    <line x1="100" y1="112" x2="132" y2="112" stroke="#5b8cc7" stroke-width="5" class="ctk ct4"/>
                    <line x1="100" y1="136" x2="124" y2="136" stroke="#1e3a5f" stroke-width="5" class="ctk ct5"/>
                    <line x1="100" y1="160" x2="116" y2="160" stroke="#1e3a5f" stroke-width="5" class="ctk ct6"/>
                    <line x1="100" y1="52" x2="52" y2="52" stroke="#fff" stroke-width="3" class="ctk ct7"/>
                    <line x1="100" y1="100" x2="60" y2="100" stroke="#fff" stroke-width="3" class="ctk ct8"/>
                    <line x1="100" y1="148" x2="68" y2="148" stroke="#fff" stroke-width="3" class="ctk ct9"/>
                </g>
            </svg>
            <span class="label">cascade time</span>
        </div>

        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#0a0a0a"/>
                <g fill="none" stroke-linecap="square">
                    <path d="M 100 100 C 100 58 32 46 32 100 C 32 154 100 142 100 100 C 100 58 168 46 168 100 C 168 154 100 142 100 100" stroke="#5b8cc7" stroke-width="4" class="iw-path"/>
                    <line x1="32" y1="100" x2="168" y2="100" stroke="#1e3a5f" stroke-width="2" class="iw-thread iwt1"/>
                    <line x1="66" y1="68" x2="134" y2="132" stroke="#1e3a5f" stroke-width="1.5" class="iw-thread iwt2"/>
                    <line x1="66" y1="132" x2="134" y2="68" stroke="#1e3a5f" stroke-width="1.5" class="iw-thread iwt3"/>
                </g>
                <rect x="94" y="94" width="12" height="12" fill="#fff" class="iw-nd iwn1"/>
                <rect x="26" y="94" width="12" height="12" fill="#90b8e0" class="iw-nd iwn2"/>
                <rect x="162" y="94" width="12" height="12" fill="#90b8e0" class="iw-nd iwn3"/>
                <rect x="60" y="62" width="10" height="10" fill="#5b8cc7" class="iw-nd iwn4"/>
                <rect x="130" y="62" width="10" height="10" fill="#5b8cc7" class="iw-nd iwn5"/>
                <rect x="60" y="128" width="10" height="10" fill="#5b8cc7" class="iw-nd iwn6"/>
                <rect x="130" y="128" width="10" height="10" fill="#5b8cc7" class="iw-nd iwn7"/>
            </svg>
            <span class="label">∞ web</span>
        </div>
    </div>

    <!-- ════════════════════════════════════════════════════════
         GRID EXPLORE — varying density, no center dots
         ════════════════════════════════════════════════════════ -->
    <h2 class="text-sm font-medium mb-4 mt-16 tracking-wide" style="color: var(--cl-text-dim);">GRID · explore</h2>
    <div class="grid grid-cols-5 gap-6 max-w-4xl">

        <!-- GE 1 ─ 2x2 large -->
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <line x1="100" y1="24" x2="100" y2="176" stroke-width="2" class="ge2v"/>
                    <path d="M 24 100 C 52 86 76 86 100 100 C 124 114 148 114 176 100" stroke-width="3" class="ge2h"/>
                </g>
            </svg>
            <span class="label">2×2 · clean</span>
        </div>

        <!-- GE 2 ─ 3x3 balanced -->
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <line x1="72" y1="24" x2="72" y2="176" stroke-width="1.5" class="ge3v ge3v1"/>
                    <line x1="128" y1="24" x2="128" y2="176" stroke-width="1.5" class="ge3v ge3v2"/>
                    <path d="M 24 72 C 48 62 72 62 100 72 C 128 82 152 82 176 72" stroke-width="2.5" class="ge3h ge3h1"/>
                    <path d="M 24 128 C 48 118 72 118 100 128 C 128 138 152 138 176 128" stroke-width="2.5" class="ge3h ge3h2"/>
                </g>
            </svg>
            <span class="label">3×3 · clean</span>
        </div>

        <!-- GE 3 ─ 4x4 tight -->
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <line x1="56" y1="24" x2="56" y2="176" stroke-width="1" class="ge4v ge4v1"/>
                    <line x1="88" y1="24" x2="88" y2="176" stroke-width="1" class="ge4v ge4v2"/>
                    <line x1="120" y1="24" x2="120" y2="176" stroke-width="1" class="ge4v ge4v3"/>
                    <path d="M 24 56 C 48 50 72 50 100 56 C 128 62 152 62 176 56" stroke-width="2" class="ge4h ge4h1"/>
                    <path d="M 24 88 C 48 82 72 82 100 88 C 128 94 152 94 176 88" stroke-width="2" class="ge4h ge4h2"/>
                    <path d="M 24 120 C 48 114 72 114 100 120 C 128 126 152 126 176 120" stroke-width="2" class="ge4h ge4h3"/>
                </g>
            </svg>
            <span class="label">4×4 · clean</span>
        </div>

        <!-- GE 4 ─ 5x5 dense -->
        <div class="cell">
            <svg viewBox="0 0 200 200" width="160" height="160">
                <rect width="200" height="200" fill="#000"/>
                <g fill="none" stroke="#fff" stroke-linecap="square">
                    <line x1="48" y1="24" x2="48" y2="176" stroke-width="0.75" class="ge5v ge5v1"/>
                    <line x1="76" y1="24" x2="76" y2="176" stroke-width="0.75" class="ge5v ge5v2"/>
                    <line x1="104" y1="24" x2="104" y2="176" stroke-width="0.75" class="ge5v ge5v3"/>
