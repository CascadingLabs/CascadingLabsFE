---
const { siteTitle } = Astro.locals.starlightRoute;
---

<a href="/" class="cl-home" title="Cascading Labs home">
    <img src="/favicon.svg" alt="Cascading Labs" class="cl-mark" width="26" height="26" />
</a>
<a href="https://qscrape.dev" class="qs-home" title="QScrape" target="_blank" rel="noopener noreferrer">
    <img src="/qscrape_favicon.svg" alt="QScrape" class="qs-mark" width="26" height="26" />
</a>
<a href="/yosoi" class="site-title sl-flex">
    <img
        src="/yosoi-favicon.svg"
        alt=""
        class="yosoi-mark"
        width="26"
        height="26"
        aria-hidden="true"
    />

    <span class="sr-only" translate="no">{siteTitle}</span>
    <span class="alpha-badge"
        >We're in Alpha. The API will not be stable untill v0.1.0</span
    >
</a>

<style>
    @layer starlight.core {
        .site-title {
            align-items: center;
            gap: var(--sl-nav-gap);
            font-size: var(--sl-text-h4);
            font-weight: 600;
            color: var(--sl-color-text-accent);
            text-decoration: none;
            white-space: nowrap;
            min-width: 0;
        }
        .alpha-badge {
            background: #1e3a5f;
            color: #90b8e0;
            font-size: 0.625rem;
            font-weight: 600;
            padding: 0.125rem 0.4rem;
            border-radius: 0;
            line-height: 1.3;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            flex-shrink: 0;
        }
    }

    .yosoi-mark {
        width: 26px;
        height: 26px;
        flex-shrink: 0;
    }

    .cl-home {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-inline-end: 0.25rem;
    }

    .cl-mark {
        width: 26px;
        height: 26px;
        border-radius: 4px;
        filter: grayscale(1);
        opacity: 0.5;
        transition: filter 0.15s ease, opacity 0.15s ease;
        will-change: filter, opacity;
    }

    .cl-home:hover .cl-mark {
        filter: grayscale(0);
        opacity: 1;
    }

    .qs-home {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-inline-end: 0.25rem;
    }

    .qs-mark {
        width: 26px;
        height: 26px;
        border-radius: 4px;
        filter: grayscale(1);
        opacity: 0.5;
        transition: filter 0.15s ease, opacity 0.15s ease;
        will-change: filter, opacity;
    }

    .qs-home:hover .qs-mark {
        filter: grayscale(0);
        opacity: 1;
    }
</style>
