---
const { siteTitle } = Astro.locals.starlightRoute;
---

<a href="/" class="cl-home" title="Cascading Labs home">
    <img data-src-dark="/favicon.svg" data-src-light="/favicon-light.svg" alt="Cascading Labs" class="cl-mark themed-img" width="26" height="26" />
</a>
<a href="https://qscrape.dev" class="qs-home" title="QScrape" target="_blank" rel="noopener noreferrer">
    <img data-src-dark="/qscrape_favicon.svg" data-src-light="/qscrape_favicon-light.svg" alt="QScrape" class="qs-mark themed-img" width="26" height="26" />
</a>
<a href="/yosoi" class="site-title sl-flex">
    <img data-src-dark="/yosoi-favicon.svg" data-src-light="/yosoi-favicon-light.svg" alt="" class="yosoi-mark themed-img" width="26" height="26" aria-hidden="true" />

    <span class="sr-only" translate="no">{siteTitle}</span>
    <span class="alpha-badge"
        >We're in Alpha. The API will not be stable untill v0.1.0</span
    >
</a>
<script is:inline>
    (function() {
        var t = document.documentElement.dataset.theme || 'dark';
        var k = t === 'light' ? 'srcLight' : 'srcDark';
        document.querySelectorAll('.themed-img').forEach(function(img) {
            if (!img.src && img.dataset[k]) img.src = img.dataset[k];
        });
    })();
</script>

<style>
    @layer starlight.core {
        .site-title {
            align-items: center;
            gap: var(--sl-nav-gap);
            font-size: var(--sl-text-h4);
            font-weight: 600;
            color: var(--sl-color-text-accent);
            text-decoration: none;
            white-space: nowrap;
            min-width: 0;
        }
        .alpha-badge {
            background: #1e3a5f;
            color: #90b8e0;
            font-size: 0.625rem;
            font-weight: 600;
            padding: 0.125rem 0.4rem;
            border-radius: 0;
            line-height: 1.3;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            flex-shrink: 0;
        }
    }

    .yosoi-mark {
        width: 26px;
        height: 26px;
        flex-shrink: 0;
    }

    .cl-home {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-inline-end: 0.25rem;
    }

    .cl-mark {
        width: 26px;
        height: 26px;
        border-radius: 4px;
        filter: grayscale(1);
        opacity: 0.5;
        transition: filter 0.15s ease, opacity 0.15s ease;
        will-change: filter, opacity;
    }

    .cl-home:hover .cl-mark {
        filter: grayscale(0);
        opacity: 1;
    }

    .qs-home {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-inline-end: 0.25rem;
    }

    .qs-mark {
        width: 26px;
        height: 26px;
        border-radius: 4px;
        filter: grayscale(1);
        opacity: 0.5;
        transition: filter 0.15s ease, opacity 0.15s ease;
        will-change: filter, opacity;
    }

    .qs-home:hover .qs-mark {
        filter: grayscale(0);
        opacity: 1;
    }
</style>
