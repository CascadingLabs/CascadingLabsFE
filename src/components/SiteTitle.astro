---
const { siteTitle, id } = Astro.locals.starlightRoute;
const isVoidCrawl = id.startsWith('voidcrawl');
const isYosoi = !isVoidCrawl;
---

<a href="/" class="cl-home" title="Cascading Labs home">
    <img data-src-dark="/favicon.svg" data-src-light="/favicon-light.svg" alt="Cascading Labs" class="cl-mark themed-img" width="26" height="26" />
</a>
<a href="https://qscrape.dev" class="qs-home" title="QScrape" target="_blank" rel="noopener noreferrer">
    <img data-src-dark="/qscrape_favicon.svg" data-src-light="/qscrape_favicon-light.svg" alt="QScrape" class="qs-mark themed-img" width="26" height="26" />
</a>
<a href="/voidcrawl" class:list={["vc-home", { active: isVoidCrawl }]} title="VoidCrawl">
    <img data-src-dark="/vc_favicon.svg" data-src-light="/vc_favicon-light.svg" alt="VoidCrawl" class="vc-mark themed-img" width="26" height="26" />
</a>
<a href="/yosoi" class:list={["site-title", "sl-flex", { active: isYosoi }]}>
    <img data-src-dark="/yosoi-favicon.svg" data-src-light="/yosoi-favicon-light.svg" alt="" class="yosoi-mark themed-img" width="26" height="26" aria-hidden="true" />

    <span class="sr-only" translate="no">{siteTitle}</span>
    {/* TODO: revisit version tags at a later date */}
    {/* {isYosoi && (
        <span class="alpha-badge"
            >We're in Alpha. The API will not be stable untill v0.1.0</span
        >
    )} */}
    {/* {isVoidCrawl && (
        <span class="alpha-badge">VoidCrawl version tag</span>
    )} */}
</a>
<script is:inline>
    (function() {
        function syncLogos(theme) {
            var k = theme === 'light' ? 'srcLight' : 'srcDark';
            document.querySelectorAll('.themed-img').forEach(function(img) {
                if (img.dataset[k]) img.src = img.dataset[k];
            });
        }
        syncLogos(document.documentElement.dataset.theme || 'dark');
        new MutationObserver(function(mutations) {
            for (var i = 0; i < mutations.length; i++) {
                if (mutations[i].attributeName === 'data-theme') {
                    syncLogos(document.documentElement.dataset.theme || 'dark');
                    break;
                }
            }
        }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    })();
</script>

<style>
    @layer starlight.core {
        .site-title {
            align-items: center;
            gap: var(--sl-nav-gap);
            font-size: var(--sl-text-h4);
            font-weight: 600;
            color: var(--sl-color-text-accent);
            text-decoration: none;
            white-space: nowrap;
            min-width: 0;
        }
        .alpha-badge {
            background: #1e3a5f;
            color: #90b8e0;
            font-size: 0.625rem;
            font-weight: 600;
            padding: 0.125rem 0.4rem;
            border-radius: 0;
            line-height: 1.3;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            flex-shrink: 0;
        }
    }

    .yosoi-mark {
        width: 26px;
        height: 26px;
        flex-shrink: 0;
        border-radius: 4px;
        filter: grayscale(1);
        opacity: 0.5;
        transition: filter 0.15s ease, opacity 0.15s ease;
        will-change: filter, opacity;
    }

    .site-title:hover .yosoi-mark,
    .site-title.active .yosoi-mark {
        filter: grayscale(0);
        opacity: 1;
    }

    .cl-home {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-inline-end: 0.25rem;
    }

    .cl-mark {
        width: 26px;
        height: 26px;
        border-radius: 4px;
        filter: grayscale(1);
        opacity: 0.5;
        transition: filter 0.15s ease, opacity 0.15s ease;
        will-change: filter, opacity;
    }

    .cl-home:hover .cl-mark {
        filter: grayscale(0);
        opacity: 1;
    }

    .qs-home {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-inline-end: 0.25rem;
    }

    .qs-mark {
        width: 26px;
        height: 26px;
        border-radius: 4px;
        filter: grayscale(1);
        opacity: 0.5;
        transition: filter 0.15s ease, opacity 0.15s ease;
        will-change: filter, opacity;
    }

    .qs-home:hover .qs-mark {
        filter: grayscale(0);
        opacity: 1;
    }

    .vc-home {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-inline-end: 0.25rem;
    }

    .vc-mark {
        width: 26px;
        height: 26px;
        border-radius: 4px;
        filter: grayscale(1);
        opacity: 0.5;
        transition: filter 0.15s ease, opacity 0.15s ease;
        will-change: filter, opacity;
    }

    .vc-home:hover .vc-mark,
    .vc-home.active .vc-mark {
        filter: grayscale(0);
        opacity: 1;
    }
</style>
