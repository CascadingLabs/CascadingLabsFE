{
	"name": "cl-fe",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"check": "biome check --write --no-errors-on-unmatched .",
		"seo": "start-server-and-test 'astro dev --port 4245' http://localhost:4245 'npx unlighthouse --site http://localhost:4245'",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@astrojs/lit": "^4.3.0",
		"@astrojs/react": "^4.4.2",
		"@astrojs/sitemap": "^3.7.0",
		"@astrojs/solid-js": "^5.1.3",
		"@astrojs/vue": "^5.1.4",
		"@tailwindcss/vite": "^4.1.18",
		"astro": "^5.17.1",
		"lit": "^3.3.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"solid-js": "^1.9.11",
		"tailwindcss": "^4.1.18",
		"vue": "^3.5.29"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"start-server-and-test": "^2.1.3"
	}
}
